rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isMember(householdId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    match /households/{householdId} {
      allow read: if isMember(householdId);
      allow create: if request.auth != null;
      allow update: if isMember(householdId);
      allow delete: if false;

      // Cap at two members enforced client-side (HouseholdService.joinByInviteCode).
      // Firestore rules can't easily count siblings, so we trust the service path here.
      match /members/{uid} {
        allow read: if isMember(householdId);
        allow create: if request.auth != null && request.auth.uid == uid;
        allow update: if request.auth != null && request.auth.uid == uid;
        allow delete: if false;
      }

      // Shared household data — any member can read/write.
      match /watchEntries/{entryId} {
        allow read, write: if isMember(householdId);

        match /episodes/{episodeId} {
          allow read, write: if isMember(householdId);
        }
      }
      match /ratings/{ratingId}        { allow read, write: if isMember(householdId); }
      match /watchlist/{itemId}        { allow read, write: if isMember(householdId); }
      match /predictions/{predictionId}{ allow read, write: if isMember(householdId); }
      match /recommendations/{recId}   { allow read, write: if isMember(householdId); }
      match /decisionHistory/{id}      { allow read, write: if isMember(householdId); }
      match /conciergeHistory/{id}     { allow read, write: if isMember(householdId); }
      match /collections/{id}          { allow read, write: if isMember(householdId); }
      match /customMoods/{id}          { allow read, write: if isMember(householdId); }
      match /wrapped/{year}            { allow read, write: if isMember(householdId); }

      // Household-scoped docs (single documents per household, addressed via
      // "default" so paths remain even-segmented as Firestore requires).
      match /tasteProfile/{id} {
        allow read, write: if isMember(householdId);
      }
      match /gamification/{id} {
        allow read, write: if isMember(householdId);
      }

      // Badges are written only by the gamificationUpdater CF (admin SDK).
      // Clients read to surface earned_at timestamps and FCM routing data.
      match /badges/{badgeId} {
        allow read: if isMember(householdId);
        allow write: if false;
      }

      // Reserved for Phase 11+ (trusted circle).
      match /trustedCircle/{friendUid}    { allow read, write: if isMember(householdId); }
      match /friendSuggestions/{sid}      { allow read, write: if isMember(householdId); }

      // "Fix this" issue queue. Batches are per-submitter: you can only see
      // or cancel your own. Creation happens server-side via the submitIssue
      // callable; clients can only flip status to 'cancelled'.
      match /issueBatches/{batchId} {
        allow read: if isMember(householdId)
          && resource.data.uid == request.auth.uid;
        allow create: if false;
        allow update: if isMember(householdId)
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'cancelled';
        allow delete: if false;
      }
    }

    // Per-user pointer for fast household lookup after sign-in.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Invite-code → householdId lookup. Any signed-in user can read/create;
    // the server-side household service is the only code path that writes these.
    match /invites/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Global Reddit-mention snapshots — written by Cloud Function, read
    // by any authed client to seed recommendations.
    match /redditMentions/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Server-only scratch space.
    match /sync/{docId}/{sub=**}   { allow read, write: if false; }
    match /_rate_limits/{token}    { allow read, write: if false; }

    // Re-score queue: admin-SDK only. The onRatingWritten trigger stamps
    // entries here; the scheduled drain reads/clears them. Clients must not
    // be able to starve the drain or spoof dirty flags for other households.
    match /rescoreQueue/{householdId} { allow read, write: if false; }
  }
}
