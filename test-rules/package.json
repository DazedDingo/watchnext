{
  "name": "watchnext-rules-tests",
  "version": "1.0.0",
  "description": "Firestore security rules emulator tests for WatchNext",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "firebase emulators:exec --only firestore --project watchnext-9920f 'jest --runInBand'",
    "test:direct": "jest --runInBand"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "firebase-tools": "^13.29.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["<rootDir>/*.test.ts"],
    "testTimeout": 20000
  }
}
