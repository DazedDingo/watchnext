<?xml version="1.0" encoding="utf-8"?>
<!--
    updatePeriodMillis = 21,600,000 ms = 6 hours.

    Android enforces a 30-minute minimum (anything lower is silently raised),
    so 6h is well above the floor. This re-fires onUpdate on the existing
    SharedPreferences payload — it does NOT fetch fresh Firestore/TMDB data.

    Data freshness pipeline (most reliable to least):
      1. `refreshUpNextWidgetEvery6Hours` Cloud Function pushes a data-only
         FCM every 6h. Background handler in main.dart writes the payload
         into home_widget prefs and triggers updateAppWidget(). Works while
         the app is killed/swiped/Doze'd.
      2. HomeWidgetService.pushUpNext() runs on AppLifecycleState.resumed —
         the moment the user opens the app, the in-app provider's freshest
         value is mirrored to the widget.
      3. This 6h re-render keeps the widget alive on launchers that
         aggressively reclaim background processes (Samsung One UI, MIUI)
         and lets relative-time strings ("Tomorrow", "In 3d") tick over
         even if both FCM and app-resume have been quiet.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="180dp"
    android:minHeight="40dp"
    android:updatePeriodMillis="21600000"
    android:initialLayout="@layout/up_next_widget"
    android:previewImage="@mipmap/ic_launcher"
    android:resizeMode="horizontal"
    android:widgetCategory="home_screen" />
