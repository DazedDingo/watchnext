<?xml version="1.0" encoding="utf-8"?>
<!--
    Tonight's Pick — 60×90 poster on the left, title/genres/score stacked on
    the right. Empty-state TextView overlays the whole tile when no pick is
    set. Provider hides the content children + shows tp_empty in that case.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:id="@+id/tp_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/tp_poster"
            android:layout_width="60dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:contentDescription="Poster" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tp_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tp_genres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8AFFFFFF"
                android:textSize="11sp"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tp_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFD0BCFF"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tp_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Open WatchNext to refresh"
        android:textColor="#8AFFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:visibility="gone" />

</FrameLayout>
