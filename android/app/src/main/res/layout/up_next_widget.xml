<?xml version="1.0" encoding="utf-8"?>
<!--
    Up Next widget — header + 3 episode rows + an empty-state line.
    Provider toggles row visibility based on up_next_count; rows beyond
    count are GONE so empty slots don't take vertical space. up_next_empty
    is the only visible child when count == 0.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header row: section label + refresh tile. The refresh TextView
         carries its own click PendingIntent (wn://refresh) which the
         Flutter bridge invalidates the providers on, then re-pushes
         widget data. Slightly bigger tap target via padding. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/up_next_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="UP NEXT"
            android:textColor="#8AFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/up_next_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#A0FFFFFF"
            android:textSize="16sp"
            android:paddingStart="10dp"
            android:paddingEnd="2dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:contentDescription="Refresh" />
    </LinearLayout>

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/up_next_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/up_next_row_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/up_next_row_0_when"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:textColor="#FFD0BCFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/up_next_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/up_next_row_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/up_next_row_1_when"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:textColor="#FFD0BCFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/up_next_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/up_next_row_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />
        <TextView
            android:id="@+id/up_next_row_2_when"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:textColor="#FFD0BCFF"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/up_next_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nothing scheduled this week"
        android:textColor="#8AFFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

</LinearLayout>
