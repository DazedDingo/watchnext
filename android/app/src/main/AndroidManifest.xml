<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <application
        android:label="WatchNext"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <!-- Don't let Flutter's engine auto-route intent.data as the
                 initial GoRouter location. Our home_widget bridge reads
                 the URI via its own method channel
                 (initiallyLaunchedFromHomeWidget) and routes through Dart;
                 leaving auto-deeplinking on caused widget refresh taps to
                 surface as "Couldn't open wn://refresh" because the engine
                 was beating the bridge to the punch. -->
            <meta-data
              android:name="flutter_deeplinking_enabled"
              android:value="false"
              />
            <!-- Note: the MAIN+LAUNCHER intent-filter has moved off MainActivity
                 and onto activity-alias entries (LauncherClassic / LauncherVivid /
                 LauncherMinimal / LauncherClapper) so users can pick their
                 launcher icon from Profile → Preferences → App icon. The
                 native AppIconSwitcher (MainActivity.kt) toggles which alias
                 is enabled. Each alias targets MainActivity, so once the user
                 launches the app the runtime is identical regardless of icon. -->
            <!-- Share-to-Save (Phase 4). Accept plain text / URLs from the
                 Android share sheet so users can forward IMDb, Letterboxd,
                 TMDB, and generic links into WatchNext. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:mimeType="text/plain"/>
            </intent-filter>
            <!-- Home-screen widget deep links. wn://title/{mt}/{tmdbId} URIs
                 set by UpNextWidgetProvider + TonightsPickWidgetProvider on
                 their RemoteViews PendingIntents land here; the Flutter
                 home_widget bridge surfaces the Uri via
                 HomeWidget.widgetClicked / initiallyLaunchedFromHomeWidget
                 and go_router routes onward. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="wn"/>
            </intent-filter>
        </activity>
        <!-- ─── Launcher icon variants (activity-alias switcher) ────────────
             Exactly one alias is enabled at a time. AppIconSwitcher (Kotlin)
             flips them via PackageManager.setComponentEnabledSetting; the
             Flutter side talks to it through the `wn/app_icon` MethodChannel.
             LauncherClassic is enabled by default (matches the original
             icon that shipped pre-v0.9.4). -->
        <activity-alias
            android:name=".LauncherClassic"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher"
            android:label="WatchNext"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".LauncherVivid"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_vivid"
            android:roundIcon="@mipmap/ic_launcher_vivid"
            android:label="WatchNext"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".LauncherMinimal"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_minimal"
            android:roundIcon="@mipmap/ic_launcher_minimal"
            android:label="WatchNext"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".LauncherClapper"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_clapper"
            android:roundIcon="@mipmap/ic_launcher_clapper"
            android:label="WatchNext"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity-alias>
        <!-- Home-screen widget receivers. Both extend
             es.antonborri.home_widget.HomeWidgetProvider so they pick up the
             SharedPreferences payload pushed from
             lib/services/home_widget_service.dart. exported=true is required
             on Android 12+ for AppWidgetHosts to bind to the receivers. -->
        <receiver
            android:name=".UpNextWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/up_next_widget_info"/>
        </receiver>
        <receiver
            android:name=".TonightsPickWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tonights_pick_widget_info"/>
        </receiver>
        <!-- Trakt OAuth callback (Phase 2). flutter_web_auth_2 routes this
             back to the in-flight authentication future via its callback activity. -->
        <activity
            android:name="com.linusu.flutter_web_auth_2.CallbackActivity"
            android:exported="true">
            <intent-filter android:label="flutter_web_auth_2">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="com.household.watchnext" android:host="trakt-callback"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher needs the stremio scheme declared here so
             canLaunchUrl() returns true on Android 11+ (package visibility). -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="stremio"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="imdb"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
    </queries>
</manifest>
